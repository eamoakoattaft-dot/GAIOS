# Copy this file to .env and fill in your real values.
# Never commit .env to git.

# From Supabase: Project Settings -> API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# From Supabase: Project Settings -> Database -> Connection string (Transaction pooler URI)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Long random string used to sign session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=
